# Environment Variables — Spur Agent

# ── LLM Providers ────────────────────────────────────────────────────
# Provide at least one. Gemini is tried first; OpenAI is the fallback.
# If neither is set, the agent runs in demo mode (no real LLM calls).
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Backend API ───────────────────────────────────────────────────────
API_PORT=3002

# ── Frontend (Next.js) ───────────────────────────────────────────────
# URL the Next.js server uses to talk to the Hono API (server-side only)
API_URL=http://localhost:3002
